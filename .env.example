# Sports Betting Model - Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# REQUIRED: The Odds API Key
# Get your free API key at: https://the-odds-api.com/
# Free tier: 500 requests/month (sufficient for daily picks)
# ============================================================
ODDS_API_KEY=your_api_key_here

# ============================================================
# OPTIONAL: Bankroll Settings
# These can also be set via the web UI
# ============================================================
# INITIAL_BANKROLL=10000
# KELLY_FRACTION=0.20
# MAX_STAKE_PCT=0.035

# ============================================================
# OPTIONAL: Model Thresholds
# Adjust strictness of bet selection
# ============================================================
# MIN_EV_PCT=7.0
# MIN_EDGE_SCORE=70
# MIN_QUALITY=60
